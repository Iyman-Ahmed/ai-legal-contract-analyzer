# Copy this file to .env and fill in your API keys

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "grok" (free), "anthropic", "openai", or "lmstudio"
LLM_PROVIDER=groq

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here          # free tier at console.groq.com — runs Llama 3, Mixtral, etc.
GROQ_MODEL=llama-3.3-70b-versatile      # or llama-3.1-8b-instant for faster/lighter inference
ANTHROPIC_API_KEY=sk-ant-your-key-here  # only needed if LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-your-openai-key-here  # only needed if LLM_PROVIDER=openai

# ── LM Studio (local) ─────────────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=lmstudio
# Start LM Studio, load a model, and enable the local server (default port 1234)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=meta-llama-3.1-8b-instruct
